# Copy to ``.env`` in this directory (``apps/api``). Loaded on import via ``track_mapper_api.config``
# (``python-dotenv``). Values already set in the process environment are not overwritten.
# Pytest sets ``TRACKMAPPER_SKIP_DOTENV=1`` so this file does not affect tests (optional: ``=0`` to load).
#
# Optional: delay between find-amazon-links web searches (milliseconds).
# AMAZON_SEARCH_DELAY_MS=2000

# Optional: max results per find-amazon-links multisite web search (default 10).
# MAX_WEB_RESULTS=10

# Optional: use Serper (https://google.serper.dev) instead of ``ddgs`` for multisite web search.
# USE_SERPER=true
# SERPER_API_KEY=

# Optional: app log level for ``track_mapper_api`` (default INFO). Uvicorn access logs are separate.
# LOG_LEVEL=INFO

# Spotify Web API (optional): import public playlists via POST /api/playlists/import-spotify.
# Uses client-credentials flow only (no user OAuth). Private playlists need user login (future).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# Alias for client secret if you already use this name locally:
# SPOTIFY_SECRET_KEY=
# ISO 3166-1 alpha-2 market for track availability (client-credentials; default US).
# SPOTIFY_MARKET=US

# OAuth redirect URI — must match Spotify app settings and the Vite app (default below).
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/spotify-callback
