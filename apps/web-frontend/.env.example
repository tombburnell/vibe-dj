# Leave empty to use same-origin `/api` (Vite dev proxy → FastAPI :8000).
# Or set full URL e.g. https://api.example.com
VITE_API_BASE_URL=

# Optional: Spotify OAuth — client id comes from GET /api/integrations/spotify/oauth/config by default.
# Only set these if the API redirect differs and you need the callback page fallback:
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/spotify-callback

# Optional. Download → Links panel: second copiable line = this string + best download URL (e.g. https://blah.com?url= + https://amazon.com/...).
# Alias: VITE_SPECIAL_LINK_PREFIX (same effect).
SPECIAL_LINK_PREFIX=
